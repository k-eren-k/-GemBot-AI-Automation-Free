      <a href="#chat-new"          class="nav-link" data-search="chat yeni sohbet new post"><span class="method-badge b-post">POST</span><span class="nav-link-text">/api/chat/new</span></a>
      <a href="#chat-history"      class="nav-link" data-search="chat geçmiş history get"><span class="method-badge b-get">GET</span><span class="nav-link-text">/api/chat/history</span></a>
