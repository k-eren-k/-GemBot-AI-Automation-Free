<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Gemini Bot — Dashboard</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/marked/9.1.6/marked.min.js"></script>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&family=Instrument+Serif:ital@0;1&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/dashboard.css">
</head>
<body>

<aside class="sidebar">
  <div class="sidebar-header">
    <div class="logo">
      <div class="logo-mark">
        <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="15" height="15"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
      </div>
      <div>
        <div class="logo-text">Gemini Bot</div>
        <div class="logo-ver">v2.0 dashboard</div>
      </div>
    </div>
  </div>

  <nav class="sidebar-nav">
    <button class="new-chat-btn" id="newChatBtn" onclick="resetChat()">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="13" height="13"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      Yeni Sohbet
    </button>

    <div class="nav-item active" id="nav-chat" onclick="switchTab('chat')">
      <span class="nav-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="14" height="14"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg></span>
      Sohbet
    </div>
    <div class="nav-item" id="nav-keys" onclick="switchTab('keys')">
      <span class="nav-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="14" height="14"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/></svg></span>
      API Keys
      <span class="nav-badge" id="keyCount"><%= typeof keys !== 'undefined' ? keys.length : 0 %></span>
    </div>
    <div class="nav-item" id="nav-stats" onclick="switchTab('stats')">
      <span class="nav-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="14" height="14"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg></span>
      İstatistikler
    </div>
    <div class="nav-item" id="nav-tutorial" onclick="window.open('/tutorial', '_blank')">
      <span class="nav-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="14" height="14"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg></span>
      Nasıl Kullanılır?
    </div>

    <div class="nav-divider"></div>

    <div class="history-section">
      <div class="history-title">
        Geçmiş
        <span class="refresh-history" onclick="loadHistory()" title="Yenile">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="11" height="11"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>
        </span>
      </div>
      <div id="historyList">
        <div style="font-size:10px;color:var(--text3);padding:6px;">Yükleniyor…</div>
      </div>
    </div>

    <div class="nav-divider"></div>
    <a href="/docs" target="_blank" class="nav-item" style="text-decoration:none">
      <span class="nav-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="14" height="14"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg></span>
      API Docs
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="9" height="9" style="margin-left:auto;opacity:.35"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
    </a>
  </nav>

  <div class="sidebar-footer">
    <div class="browser-widget">
      <div class="bw-header">
        <div class="bw-dot closed" id="bwDot"></div>
        <span class="bw-label">Tarayıcı</span>
        <span class="bw-status" id="bwStatus">Kapalı</span>
      </div>
      <button class="bw-btn" id="bwBtn" onclick="toggleBrowser()">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="11" height="11"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
        Tarayıcıyı Başlat
      </button>
    </div>
  </div>
</aside>

<main class="main">
  <div class="topbar">
    <span class="topbar-title" id="topbarTitle">Sohbet</span>
    <div class="topbar-right">
      <div class="tb-pill">
        <div class="status-dot idle" id="sDot"></div>
        <span id="sText">Hazır</span>
      </div>
      <div class="model-picker">
        <div class="model-opt active" id="m-flash"   onclick="setModelUI('Hızlı')">Hızlı</div>
        <div class="model-opt"        id="m-thought" onclick="setModelUI('Düşünen')">Düşünen</div>
        <div class="model-opt"        id="m-pro"     onclick="setModelUI('Pro')">Pro</div>
      </div>
      <button class="clear-btn" id="clearChatBtn" onclick="clearChat()">Temizle</button>
    </div>
  </div>

  <!-- CHAT TAB -->
  <div class="tab-content active" id="tab-chat">
    <div style="display:flex;flex-direction:column;flex:1;overflow:hidden;">

      <div class="messages" id="msgs">
        <div class="welcome-state" id="welcomeState">
          <div class="welcome-mark">
            <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="22" height="22"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
          </div>
          <div class="welcome-title">Gemini Bot'a Hoş Geldin</div>
          <div class="welcome-sub">Playwright ile kontrol edilen Gemini AI asistanı. Aşağıya yaz ve gönder.</div>
          <div class="quick-btns">
            <button class="quick-btn" onclick="quickSend('Merhaba! Kendini tanıtır mısın?')">👋 Tanış</button>
            <button class="quick-btn" onclick="quickSend('Bugün ne yapabilirim?')">🎯 Görev öner</button>
            <button class="quick-btn" onclick="quickSend('Bana kısa bir özet hazırla')">📋 Özet yaz</button>
            <button class="quick-btn" onclick="quickSend('Bir proje planı oluştur')">🗺️ Plan yap</button>
          </div>
        </div>
      </div>

      <!-- ── INPUT BAR: sadece textarea + mod butonu + gönder ── -->
      <div class="input-bar">
        <div class="input-row">
          <textarea
            class="msg-input"
            id="msgInput"
            placeholder="Mesajını yaz… (Enter → gönder, Shift+Enter → yeni satır)"
            onkeydown="handleKey(event)"
            rows="1"
            oninput="autoResize(this)"
          ></textarea>

          <!-- Gizli mod seçici: sadece ikon, hover'da açılır -->
          <div class="mode-wrap" id="modeWrap">
            <button class="mode-toggle" id="modeToggle" onclick="toggleModeMenu(event)" title="Gelişmiş mod">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="14" height="14"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14M4.93 4.93a10 10 0 0 0 0 14.14"/></svg>
              <span class="mode-label" id="modeLabelBtn" style="display:none">chat</span>
            </button>
            <div class="mode-menu" id="modeMenu">
              <div class="mode-menu-title">Yanıt Modu</div>
              <button class="mode-menu-item active" data-mode="chat"      onclick="pickMode('chat')">Genel <span>Varsayılan</span></button>
              <button class="mode-menu-item"        data-mode="plan"      onclick="pickMode('plan')">Planlama <span>Adım adım aksiyon</span></button>
              <button class="mode-menu-item"        data-mode="summarize" onclick="pickMode('summarize')">Özet <span>Kısa & net</span></button>
              <button class="mode-menu-item"        data-mode="analyze"   onclick="pickMode('analyze')">Analiz <span>Derin inceleme</span></button>
              <button class="mode-menu-item"        data-mode="code"      onclick="pickMode('code')">Kod <span>Teknik yardım</span></button>
              <button class="mode-menu-item"        data-mode="debug"     onclick="pickMode('debug')">Debug <span>Hata ayıklama</span></button>
            </div>
          </div>

          <button class="send-btn" id="sendBtn" onclick="send()">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
          </button>
        </div>

        <!-- Seçilmiş mod "chat" dışındaysa gösterilir -->
        <div class="mode-active-bar" id="modeActiveBar" style="display:none">
          <span id="modeActiveName"></span>
          <button onclick="pickMode('chat')" title="Modu sıfırla">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="10" height="10"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
          </button>
        </div>
      </div>

    </div>
  </div>

  <!-- KEYS TAB -->
  <div class="tab-content" id="tab-keys">
    <div class="keys-tab">
      <div class="tab-section-title">API Key Yönetimi</div>
      <div class="tab-section-sub">
        Key'leri <code>Authorization: Bearer gmb_xxx</code> ya da <code>x-api-key: gmb_xxx</code> header'ı ile kullan.
      </div>
      <div class="new-key-card">
        <div class="card-label">Yeni Key Oluştur</div>
        <div class="new-key-row">
          <input class="text-input" id="keyLabel" type="text" placeholder="Etiket: production, dev, test…" maxlength="50">
          <button class="btn btn-primary btn-sm" onclick="createKey()">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="11" height="11"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Oluştur
          </button>
        </div>
      </div>
      <div class="keys-list" id="keysList">
        <% if (typeof keys !== 'undefined') { keys.forEach(k => { %>
        <div class="key-card" id="kcard-<%= k.id %>">
          <div class="key-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="14" height="14"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/></svg>
          </div>
          <div class="key-info">
            <div class="key-label"><%= k.label %></div>
            <div class="key-value-row">
              <span class="key-value" id="kv-<%= k.id %>"><%= k.keyFull %></span>
              <button class="btn-copy" onclick="copyKey('<%= k.keyFull %>')">Kopyala</button>
            </div>
            <div class="key-meta">
              Oluşturuldu: <strong><%= new Date(k.createdAt).toLocaleString('tr-TR') %></strong>
              · İstek: <strong><%= k.totalRequests || 0 %></strong>
              <% if(k.lastUsed) { %> · Son: <%= new Date(k.lastUsed).toLocaleString('tr-TR') %><% } %>
            </div>
          </div>
          <div class="key-actions">
            <button class="btn btn-danger btn-sm" onclick="deleteKey('<%= k.id %>')">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="11" height="11"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/></svg>
              Sil
            </button>
          </div>
        </div>
        <% }) } %>
        <% if (typeof keys === 'undefined' || keys.length === 0) { %>
        <div style="text-align:center;padding:28px;color:var(--text3);font-size:12px;border:1px dashed var(--border);border-radius:10px;">
          Henüz key yok. Yukarıdan oluşturabilirsin.
        </div>
        <% } %>
      </div>
    </div>
  </div>

  <!-- STATS TAB -->
  <div class="tab-content" id="tab-stats">
    <div class="stats-tab">
      <div class="tab-section-title">Kullanım İstatistikleri</div>
      <div class="tab-section-sub">Tüm API key'lerinin toplu kullanım verileri.</div>
      <div class="stats-grid">
        <div class="stat-card"><div class="stat-val accent" id="stat-total"><%= typeof stats !== 'undefined' ? stats.total : 0 %></div><div class="stat-label">Toplam</div></div>
        <div class="stat-card"><div class="stat-val green" id="stat-rate"><%= typeof stats !== 'undefined' ? stats.successRate : 0 %>%</div><div class="stat-label">Başarı</div></div>
        <div class="stat-card"><div class="stat-val" id="stat-avg"><%= typeof stats !== 'undefined' ? stats.avgResponseTime : 0 %>ms</div><div class="stat-label">Ort. Yanıt</div></div>
        <div class="stat-card"><div class="stat-val yellow" id="stat-24h"><%= typeof stats !== 'undefined' ? stats.last24h : 0 %></div><div class="stat-label">Son 24s</div></div>
      </div>
      <div class="chart-card">
        <div class="chart-header">
          <div class="chart-title">Saatlik — Son 24h</div>
          <div class="chart-legend">
            <span><span class="legend-dot" style="background:var(--accent);"></span>Başarılı</span>
            <span><span class="legend-dot" style="background:var(--red);"></span>Hata</span>
          </div>
        </div>
        <div id="hourlyChartWrap">
          <% const statsObj = typeof stats !== 'undefined' ? stats : {total:0,hourly:{}}; %>
          <% if (statsObj.total === 0) { %>
          <div class="empty-chart">Henüz istatistik yok.</div>
          <% } else { %>
          <div class="bar-chart-wrap">
            <% const hours = Object.entries(statsObj.hourly || {}); const maxH = Math.max(...hours.map(([,v])=>v.ok+v.err), 1); %>
            <% hours.forEach(([label, v]) => {
              const total = v.ok + v.err;
              const hOk  = total ? Math.max(Math.round((v.ok  / maxH) * 60), v.ok  ? 3 : 0) : 0;
              const hErr = total ? Math.max(Math.round((v.err / maxH) * 60), v.err ? 3 : 0) : 0;
            %>
            <div class="bar-col">
              <div class="bar-stack" style="height:60px;display:flex;flex-direction:column;justify-content:flex-end;">
                <% if(hErr>0){%><div class="bar err" style="height:<%=hErr%>px" title="<%=v.err%> hata"></div><%}%>
                <% if(hOk >0){%><div class="bar ok"  style="height:<%=hOk %>px" title="<%=v.ok%> başarılı"></div><%}%>
              </div>
              <div class="bar-label"><%= label.slice(0,2) %></div>
            </div>
            <% }) %>
          </div>
          <% } %>
        </div>
      </div>
      <div class="chart-card">
        <div class="chart-header"><div class="chart-title">Son İstekler</div></div>
        <div id="recentListWrap">
          <% const recentArr = (typeof stats !== 'undefined' && stats.recent) ? stats.recent : []; %>
          <% if (recentArr.length === 0) { %>
          <div class="empty-chart">Henüz istek yok.</div>
          <% } else { %>
          <div class="recent-list">
            <% recentArr.slice(0,15).forEach(r => { %>
            <div class="recent-row">
              <span class="recent-status <%=r.status>=200&&r.status<400?'ok':'err'%>"><%= r.status %></span>
              <span class="recent-method"><%= r.method %></span>
              <span class="recent-ep"><%= r.endpoint %></span>
              <span class="recent-key"><%= r.apiKeyLabel %></span>
              <span class="recent-rt"><%= r.responseTime %>ms</span>
              <span class="recent-time"><%= new Date(r.timestamp).toLocaleTimeString('tr-TR') %></span>
            </div>
            <% }) %>
          </div>
          <% } %>
        </div>
      </div>
      <div id="keyTableWrap">
        <% const byKey = (typeof stats !== 'undefined' && stats.byKey) ? stats.byKey : {}; %>
        <% if (Object.keys(byKey).length > 0) { %>
        <div class="chart-card">
          <div class="chart-header"><div class="chart-title">Key Bazlı</div></div>
          <table class="key-table">
            <tr><th>Key</th><th>Toplam</th><th>Başarılı</th><th>Oran</th></tr>
            <% Object.entries(byKey).forEach(([lbl,v]) => { %>
            <tr>
              <td><%= lbl %></td>
              <td style="color:var(--text2)"><%= v.total %></td>
              <td style="color:var(--green)"><%= v.success %></td>
              <td><%= Math.round(v.success/v.total*100) %>%</td>
            </tr>
            <% }) %>
          </table>
        </div>
        <% } %>
      </div>
    </div>
  </div>
</main>

<div id="progressAlert" class="progress-alert">
  <div class="progress-header">
    <span class="progress-text" id="progressText">Yükleniyor...</span>
    <span class="progress-perc" id="progressPerc">0%</span>
  </div>
  <div class="progress-bar-bg"><div class="progress-bar-fill" id="progressFill"></div></div>
</div>

<script src="/js/dashboard.js"></script>
</body>
</html>
